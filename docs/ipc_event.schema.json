{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "event_id": {
            "type": "string"
        },
        "event_type": {
            "type": "string"
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "payload": {
            "type": "object"
        }
    },
    "required": ["event_id", "event_type", "timestamp", "payload"]
}
