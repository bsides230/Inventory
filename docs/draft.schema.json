{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "id": {
            "type": "string"
        },
        "user_id": {
            "type": "string"
        },
        "draft_name": {
            "type": "string"
        },
        "state": {
            "type": "string",
            "enum": ["active", "submitting", "submitted", "abandoned"]
        },
        "version": {
            "type": "integer"
        },
        "is_rush": {
            "type": "boolean"
        },
        "needed_by": {
            "type": ["string", "null"]
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "item_id": {
                        "type": "string"
                    },
                    "category_id": {
                        "type": "string"
                    },
                    "item_name": {
                        "type": "string"
                    },
                    "quantity": {
                        "type": "integer"
                    },
                    "unit": {
                        "type": "string"
                    }
                },
                "required": ["item_id", "category_id", "item_name", "quantity", "unit"]
            }
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": ["id", "user_id", "status", "items", "created_at", "updated_at"]
}
